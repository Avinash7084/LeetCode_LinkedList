
class Solution {
public:
    ListNode* removeElements(ListNode* head, int valu) {
        if (head == NULL)
            return NULL;

        while (head != NULL && head->val == valu) {
            ListNode* temp = head;
            head = temp->next;
            delete temp;
        }
        ListNode* curr = head;
        while (curr != NULL || curr->next != NULL) {
            if (curr->next->val == valu) {
                ListNode* temp = curr->next;
                curr->next = temp->next;
                delete temp;
            } else
                curr = curr->next;
        }
        return head;
    }
};
